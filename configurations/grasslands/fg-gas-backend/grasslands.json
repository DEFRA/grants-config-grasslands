            "properties": {
              "business": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "reference", "email", "phone", "address"],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "reference": {
                    "type": "string"
                  },
                  "email": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["address"],
                    "properties": {
                      "address": {
                        "type": "string",
                        "format": "email"
                      }
                    }
                  },
                  "phone": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["mobile"],
                    "properties": {
                      "mobile": {
                        "type": "string"
                      }
                    }
                  },
                  "address": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["city", "postalCode", "line1"],
                    "properties": {
                      "city": {
                        "type": "string"
                      },
                      "postalCode": {
                        "type": "string"
                      },
                      "line1": {
                        "type": "string"
                      },
                      "line2": {
                        "type": "string"
                      },
                      "line3": {
                        "type": "string"
                      },
                      "line4": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "customer": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["title", "first", "last"],
                    "properties": {
                      "title": {
                        "type": "string"
                      },
                      "first": {
                        "type": "string"
                      },
                      "middle": {
                        "type": "string"
                      },
                      "last": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "detailsConfirmedAt": {
            "type": "string",
            "format": "date-time"
          },
          "selectedParcelId": {
            "type": "string"
          },
          "actionCode": {
            "type": "string"
          }
