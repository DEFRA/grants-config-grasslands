        "type": "object",
        "additionalProperties": false,
        "required": [
          "referenceNumber",
          "businessDetailsUpToDate",
          "confirmEligibility",
          "confirmLandDetailsUpToDate",
          "applicant",
          "detailsConfirmedAt",
          "selectedParcelId",
          "actionCode"
        ],
        "properties": {
          "referenceNumber": {
            "type": "string"
          },
          "businessDetailsUpToDate": {
